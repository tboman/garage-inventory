<mxfile host="app.diagrams.net">
  <diagram id="grants" name="Identity and Grants">
    <mxGraphModel adaptiveColors="auto" dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Identity &amp; OAuth Grants: ChatGPT &#8592;&#8594; StorageLoot MCP &#8592;&#8594; eBay" style="text;html=1;align=center;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="280" y="10" width="840" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="Grants (color = who approves)" style="rounded=0;fillColor=#FFFFFF;strokeColor=#666666;verticalAlign=top;fontSize=11;fontStyle=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="240" height="140" as="geometry" />
        </mxCell>
        <mxCell id="leg1" value="[1] Google OIDC &#8212; approved by user" style="rounded=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;align=left;spacingLeft=6" vertex="1" parent="legend">
          <mxGeometry x="10" y="25" width="220" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg2" value="[2] eBay OAuth &#8212; approved by user" style="rounded=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;align=left;spacingLeft=6" vertex="1" parent="legend">
          <mxGeometry x="10" y="52" width="220" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg3" value="[3] MCP agent OAuth &#8212; user + DCR" style="rounded=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;align=left;spacingLeft=6" vertex="1" parent="legend">
          <mxGeometry x="10" y="79" width="220" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg4" value="[4] eBay client credentials &#8212; no user" style="rounded=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;align=left;spacingLeft=6" vertex="1" parent="legend">
          <mxGeometry x="10" y="106" width="220" height="22" as="geometry" />
        </mxCell>
        <mxCell id="user" value="User&#10;(Google account)" style="rounded=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=13;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="580" y="55" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="chatgpt" value="ChatGPT&#10;(AI Agent / OAuth client)&#10;&#10;Holds:&#10;&#8226; MCP access token&#10;&#8226; MCP refresh token" style="rounded=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="40" y="440" width="240" height="150" as="geometry" />
        </mxCell>
        <mxCell id="ebay" value="eBay&#10;(Marketplace IdP / API)&#10;&#10;Issues:&#10;&#8226; User refresh token (sell.*)&#10;&#8226; App client-credentials token" style="rounded=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="1130" y="440" width="240" height="150" as="geometry" />
        </mxCell>
        <mxCell id="sl" value="StorageLoot" style="rounded=0;fillColor=#FAFAFA;strokeColor=#666666;verticalAlign=top;fontSize=14;fontStyle=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="310" y="170" width="800" height="680" as="geometry" />
        </mxCell>
        <mxCell id="consent" value="Consent UI&#10;storageloot.shop/authorize" style="rounded=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=11;align=center" vertex="1" parent="sl">
          <mxGeometry x="30" y="40" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="mcp" value="MCP Server&#10;mcp.storageloot.shop&#10;(Cloud Run)" style="rounded=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=11;align=center" vertex="1" parent="sl">
          <mxGeometry x="470" y="40" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fbauth" value="Firebase Auth&#10;(user identities &#8212; Google sign-in)" style="rounded=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;align=center" vertex="1" parent="sl">
          <mxGeometry x="30" y="140" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fs" value="Firestore (hunapuka-34ce6) &#8212; identity &amp; grant storage" style="rounded=0;fillColor=#FFFFFF;strokeColor=#999999;verticalAlign=top;fontSize=11;fontStyle=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;dashed=1" vertex="1" parent="sl">
          <mxGeometry x="30" y="240" width="740" height="420" as="geometry" />
        </mxCell>
        <mxCell id="col_user" value="users/{uid}&#10;Firebase Auth profile (email, displayName)" style="rounded=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;align=center" vertex="1" parent="fs">
          <mxGeometry x="20" y="40" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="col_ebay" value="users/{uid}/integration_tokens/ebay&#10;eBay USER refresh token (sell.inventory, sell.account)" style="rounded=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;align=center" vertex="1" parent="fs">
          <mxGeometry x="380" y="40" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="col_clients" value="mcp_clients/{client_id}&#10;DCR record: client_name, redirect_uris,&#10;registered scopes, auth method" style="rounded=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;align=center" vertex="1" parent="fs">
          <mxGeometry x="20" y="120" width="340" height="70" as="geometry" />
        </mxCell>
        <mxCell id="col_auth" value="auth_sessions/{code}&#10;PKCE authorization code (one-time, 60s TTL)&#10;&#8594; binds uid + client + approved scopes" style="rounded=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;align=center" vertex="1" parent="fs">
          <mxGeometry x="380" y="120" width="340" height="70" as="geometry" />
        </mxCell>
        <mxCell id="col_rt" value="mcp refresh tokens&#10;Agent long-lived grant: uid + client_id + approved scopes + token hash" style="rounded=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;align=center" vertex="1" parent="fs">
          <mxGeometry x="20" y="215" width="700" height="60" as="geometry" />
        </mxCell>
        <mxCell id="col_note" value="Note: the eBay user token (green) and the MCP agent token (orange) are deliberately kept in separate collections. The agent never sees the eBay refresh token; only future write tools (revise/end listing) would load it server-side on the user&apos;s behalf." style="rounded=0;fillColor=none;strokeColor=none;fontSize=10;fontStyle=2;align=left;whiteSpace=wrap;html=1;spacingLeft=4;spacingRight=4" vertex="1" parent="fs">
          <mxGeometry x="20" y="300" width="700" height="100" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="[1] Google OIDC sign-in&#10;&#8594; establishes uid" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6C8EBF;strokeWidth=2;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;rounded=0;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="user" target="fbauth">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e1s" value="stored" style="endArrow=open;dashed=1;strokeColor=#6C8EBF;fontSize=9;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="fbauth" target="col_user">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="[2] eBay OAuth consent&#10;scopes: sell.inventory, sell.account&#10;+ offline refresh" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82B366;strokeWidth=2;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="user" target="ebay">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2s" value="refresh token returned&#10;&#8594; stored server-side" style="endArrow=open;dashed=1;strokeColor=#82B366;fontSize=9;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="ebay" target="col_ebay">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3a" value="[3a] DCR /register&#10;(no user involved)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#D79B00;strokeWidth=2;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;rounded=0;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0" edge="1" parent="1" source="chatgpt" target="mcp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3as" value="DCR record stored" style="endArrow=open;dashed=1;strokeColor=#D79B00;fontSize=9;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="mcp" target="col_clients">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3b" value="[3b] Approve agent scopes&#10;openid profile market:read market:search" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#D79B00;strokeWidth=2;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;rounded=0;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="user" target="consent">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3bs" value="auth code minted" style="endArrow=open;dashed=1;strokeColor=#D79B00;fontSize=9;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="consent" target="col_auth">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3c" value="[3c] code &#8594; token exchange&#10;agent refresh token issued" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#D79B00;strokeWidth=2;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;rounded=0;exitX=0;exitY=0.7;exitDx=0;exitDy=0;entryX=1;entryY=0.3;entryDx=0;entryDy=0" edge="1" parent="1" source="mcp" target="chatgpt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3cs" value="refresh token hash stored" style="endArrow=open;dashed=1;strokeColor=#D79B00;fontSize=9;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="mcp" target="col_rt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="[4] Client credentials grant&#10;(app token for Browse API &#8212; no user)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#B85450;strokeWidth=2;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0" edge="1" parent="1" source="mcp" target="ebay">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
