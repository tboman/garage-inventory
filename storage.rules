rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /listings/{listingId}/{photo} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /groups/{groupId}/{photo} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
