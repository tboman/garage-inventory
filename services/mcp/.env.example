# Local dev only — production loads this from Secret Manager.
# Generate with: npx tsx scripts/generate-keypair.ts
MCP_JWT_PRIVATE_JWK=

# Issuer URL the service advertises in OIDC discovery + JWTs.
ISSUER=http://localhost:8080

# Firebase project — required for Firestore (mcp_clients, etc.) and, when
# MCP_JWT_PRIVATE_JWK is not set, Secret Manager fallback.
# For local dev: run `gcloud auth application-default login` so the Admin SDK
# can authenticate, or set GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json.
GCP_PROJECT=hunapuka-34ce6

PORT=8080

# eBay app-level credentials used for Browse API (Client Credentials grant).
# These are the same ones StorageLoot web uses to link user accounts.
# EBAY_ENV=production            # 'production' (default) or 'sandbox'
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=            # inline for local dev; in prod leave unset
# EBAY_CLIENT_SECRET_NAME=EBAY_CLIENT_SECRET   # Secret Manager key override
